# ──────────────────────────────────────────────────────────────────────────────
# Template de variáveis de ambiente — Experience API
#
# COMO USAR:
#   1. Copie este arquivo para .env (nunca versione o .env com valores reais)
#   2. Preencha os valores reais
#   3. Em produção (AWS EC2), configure diretamente como variáveis de ambiente
#      da instância ou via docker run --env-file .env
#
# ──────────────────────────────────────────────────────────────────────────────

# ── Banco de dados (AWS RDS PostgreSQL) ───────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://<rds-endpoint>:5432/db_experience
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<senha_do_rds>

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere uma chave segura: openssl rand -base64 32
JWT_SECRET=<sua_chave_jwt_em_base64>
JWT_EXPIRATION=86400000

# ── E-mail (AWS SES em produção) ──────────────────────────────────────────────
MAIL_HOST=email-smtp.us-east-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=<ses_smtp_user>
MAIL_PASSWORD=<ses_smtp_password>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Separado por vírgula. Inclua o IP/domínio de onde o app e o Node-RED chamam a API.
# Exemplo produção: https://app.experience.com,http://<ip-nodered>:1880
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081
