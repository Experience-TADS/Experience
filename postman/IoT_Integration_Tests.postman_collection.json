          "name": "1. Criar Veículo 10002",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code é 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Veículo criado com status AGUARDANDO\", function () {",
                  "    var jsonData = pm.response.json();",
